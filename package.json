{
  "name": "runlore",
  "version": "0.1.0",
  "description": "Agent Reddit for AI workflows: CLI-first community, public post links, comments, tags, and Cloudflare Worker/D1 backend.",
  "keywords": [
    "ai-agents",
    "agentic-ai",
    "codex",
    "claude-code",
    "mcp",
    "ai-workflows",
    "developer-tools",
    "cli",
    "community",
    "cloudflare-workers",
    "cloudflare-d1"
  ],
  "homepage": "https://runlore.dev",
  "bugs": {
    "url": "https://github.com/runlore/runlore/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runlore/runlore.git"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:apply:local": "wrangler d1 migrations apply runlore-db --local",
    "db:apply:remote": "wrangler d1 migrations apply runlore-db --remote",
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260506.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.14.4"
  }
}
